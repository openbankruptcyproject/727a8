<script>
(function() {
  var priorType = document.getElementById('priorType');
  var seventyGroup = document.getElementById('seventyPctGroup');
  priorType.addEventListener('change', function() {
    if (this.value === '13' || this.value === '12') {
      seventyGroup.style.display = 'block';
    } else {
      seventyGroup.style.display = 'none';
    }
  });
})();

function calculate() {
  var priorType = document.getElementById('priorType').value;
  var filingDateStr = document.getElementById('filingDate').value;
  var seventyPct = document.getElementById('seventyPct').checked;
  var resultDiv = document.getElementById('result');

  if (!filingDateStr) {
    resultDiv.innerHTML = '<div class="callout red"><h4>Please enter a filing date</h4><p>Enter the date your prior bankruptcy case was filed (the petition date).</p></div>';
    return;
  }

  var parts = filingDateStr.split('-');
  var filingDate = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]));
  var today = new Date();
  today.setHours(0, 0, 0, 0);

  var yearsToAdd;
  var statute;
  var explanation;

  if (priorType === '7' || priorType === '11') {
    yearsToAdd = 8;
    statute = '727(a)(8)';
    explanation = 'Section 727(a)(8) requires 8 years between filing dates when the prior discharge was under Chapter ' + priorType + '.';
  } else {
    // Chapter 12 or 13
    if (seventyPct) {
      yearsToAdd = 0;
      statute = '727(a)(9) exception';
      explanation = 'If you paid at least 70% of unsecured claims and the plan was proposed in good faith with best effort, the 6-year bar under Section 727(a)(9) does not apply. However, this determination is made by the court, not automatically.';
    } else {
      yearsToAdd = 6;
      statute = '727(a)(9)';
      explanation = 'Section 727(a)(9) requires 6 years between filing dates when the prior discharge was under Chapter ' + priorType + '.';
    }
  }

  if (yearsToAdd === 0) {
    resultDiv.innerHTML = '<div class="result-eligible"><h4>Potentially Eligible (Court Determination Required)</h4>' +
      '<p>' + explanation + '</p>' +
      '<p class="result-note">The court will evaluate whether the 70% payment threshold was met and whether the plan was proposed in good faith with best effort. You should verify this with your attorney and have documentation of plan payments ready.</p></div>';
    if (typeof gtag === 'function') {
      gtag('event', 'calculator_result', { event_category: '727_calculator', event_label: 'ch' + priorType + '_70pct_exception', prior_chapter: priorType });
    }
    return;
  }

  var eligibleDate = new Date(filingDate.getFullYear() + yearsToAdd, filingDate.getMonth(), filingDate.getDate());
  var eligible = today >= eligibleDate;

  var filingFormatted = filingDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  var eligibleFormatted = eligibleDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

  if (eligible) {
    var html = '<div class="result-eligible">';
    html += '<h4>Eligible to File Chapter 7</h4>';
    html += '<p>Your prior Chapter ' + priorType + ' was filed on <strong>' + filingFormatted + '</strong>. ';
    html += 'The ' + yearsToAdd + '-year bar under ' + statute + ' expired on <strong>' + eligibleFormatted + '</strong>.</p>';
    html += '<p>' + explanation + '</p>';
    html += '<p class="result-note">You are past the ' + statute + ' bar window. Other eligibility requirements (means test, credit counseling, etc.) still apply. This does not constitute legal advice.</p>';
    html += '</div>';
  } else {
    var diffMs = eligibleDate - today;
    var diffDays = Math.ceil(diffMs / (1000 * 60 * 60 * 24));
    var diffMonths = (eligibleDate.getFullYear() - today.getFullYear()) * 12 + (eligibleDate.getMonth() - today.getMonth());
    var remainLabel = diffDays < 60 ? diffDays + ' days' : Math.round(diffMonths) + ' months';

    var html = '<div class="result-barred">';
    html += '<h4>Not Yet Eligible for Chapter 7 Discharge</h4>';
    html += '<p>Your prior Chapter ' + priorType + ' was filed on <strong>' + filingFormatted + '</strong>. ';
    html += 'Under ' + statute + ', you must wait until <strong>' + eligibleFormatted + '</strong> (' + remainLabel + ' from today).</p>';
    html += '<p>' + explanation + '</p>';
    html += '<p class="result-note"><strong>Alternatives:</strong> You may be able to file <a href="/vs-1328f.html">Chapter 13</a> in the meantime, though Section 1328(f) may limit your Chapter 13 discharge. Use the <a href="https://1328f.com/check.html">1328f.com screener</a> to check all options.</p>';
    html += '</div>';
  }

  resultDiv.innerHTML = html;

  if (typeof gtag === 'function') {
    gtag('event', 'calculator_result', {
      event_category: '727_calculator',
      event_label: eligible ? 'eligible' : 'barred',
      prior_chapter: priorType,
      statute: statute,
      days_remaining: eligible ? 0 : diffDays
    });
  }
}
</script>

